# Host-local development (backend run on machine, Postgres/Redis via Docker).
# For full Docker Compose, env vars are injected by docker-compose.yml — no .env required.

SECRET_KEY=change-me-for-local-dev
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

DB_NAME=pricepulse
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True

# Host Redis is published on 6380 (container: 6379)
CELERY_BROKER_URL=redis://localhost:6380/0
CELERY_RESULT_BACKEND=redis://localhost:6380/0
CELERY_TIMEZONE=Asia/Kolkata

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_CACHE_URL=redis://localhost:6380/1
USE_REDIS_CACHE=True

# fake | hybrid | live
# fake = deterministic demo prices (fast, reliable)
# hybrid = live Blinkit/Zepto then FakeProvider fallback
# live = live only (may return empty)
PROVIDER_MODE=fake
PROVIDER_TIMEOUT=8
PROVIDER_MAX_RETRIES=2
PROVIDER_RATE_LIMIT_PER_MINUTE=30
PROVIDER_CACHE_TTL=600
PROVIDER_USE_PLAYWRIGHT=False
PROVIDER_LATITUDE=28.6139
PROVIDER_LONGITUDE=77.2090

# Optional paid aggregators (never expose to frontend)
QUICKCOMMERCE_API_KEY=
PARSE_API_KEY=
FOODSPARK_API_KEY=

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@pricepulse.local
